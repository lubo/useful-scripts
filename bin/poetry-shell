#!/bin/bash
#
# Spawns a subshell with Poetry virtual environment activated. Alternative to
# https://github.com/python-poetry/poetry-plugin-shell.

set -e

PARENT_DIR=$(dirname "$0")
RUN_IN_INTERACTIVE_SHELL=$(realpath "${PARENT_DIR}/../run-in-interactive-shell")
COMMAND=$(poetry env activate)

exec "${RUN_IN_INTERACTIVE_SHELL}" "${COMMAND}"
