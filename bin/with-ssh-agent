#!/bin/bash
#
# Wraps a program in ssh-agent and adds keys into the agent. If no program is
# provided, then it spawns an interactive shell.

set -eo pipefail

# By default, Bubblewrap remaps all users except the current one to 65534. When
# files in /etc/ssh are not owned by root and the current user or their
# permissions are not 0644, SSH fails with:
#
#   Bad owner or permissions on /etc/ssh/…
#
# See:
# https://github.com/openssh/openssh-portable/blob/eb34f95206c3556e10046f091ea95431c4be84f8/readconf.c#L2640-L2642
# On Arch Linux, /etc/ssh/ssh_config.d contains a symlink and symlinks on Linux
# always have 0777 permissions. The only way to satisfy this condition when
# unprivileged is to work under user 65534.
SANDBOX_GID=65534
SANDBOX_UID=65534

if [[ ! "${WITH_SSH_AGENT}" ]]; then
	export WITH_SSH_AGENT=1

	APP_DIR=${XDG_RUNTIME_DIR:?}/with-ssh-agent
	mkdir -p "${APP_DIR}"

	# Running ssh-agent without arguments requires the home directory in
	# /etc/passwd to be set correctly to work properly. See:
	# https://github.com/openssh/openssh-portable/blob/eb34f95206c3556e10046f091ea95431c4be84f8/ssh-add.c#L1027
	GID=$(id -g)
	getent group "${GID}" |
		awk \
			-F : \
			-v OFS=: \
			-v "gid=${SANDBOX_GID}" \
			'{$3=gid}1' \
			>"${APP_DIR}/group"
	getent passwd "${UID}" |
		awk \
			-F : \
			-v OFS=: \
			-v "gid=${SANDBOX_GID}" \
			-v "uid=${SANDBOX_UID}" \
			'{$3=uid; $4=gid}1' \
			>"${APP_DIR}/passwd"

	exec bwrap \
		--die-with-parent \
		--dev-bind / / \
		--bind {"${APP_DIR}",/etc}/group \
		--bind {"${APP_DIR}",/etc}/passwd \
		--unshare-user \
		--uid "${SANDBOX_UID}" \
		--gid "${SANDBOX_GID}" \
		--perms 0700 \
		--tmpfs ~/.ssh/agent \
		-- \
		"$0" "$@"
fi

if [[ ! "${SSH_AGENT_PID}" ]]; then
	exec ssh-agent -- "$0" "$@"
fi

ssh-add || true

if [[ "$#" -gt 0 ]]; then
	exec "$@"
fi

PARENT_DIR=$(dirname "$0")
RUN_IN_INTERACTIVE_SHELL=$(realpath "${PARENT_DIR}/../run-in-interactive-shell")
# shellcheck disable=SC2016
COMMAND=' PS1="(ssh-agent) ${PS1}"'

exec "${RUN_IN_INTERACTIVE_SHELL}" "${COMMAND}"
